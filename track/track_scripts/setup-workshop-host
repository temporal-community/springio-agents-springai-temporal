<body>
<h1>🔌 Network Control Panel</h1>
<p class="subtitle">Toggle external service access for the workshop demos</p>

<div class="section-label">External Services</div>
<div id="services"></div>

<div class="section-label" style="margin-top:20px;">Kill Switch</div>
<div class="kill-card" id="kill-card">
  <div class="card-header">
    <div>
      <div class="kill-label">⚡ Kill All External Traffic</div>
      <div class="kill-sub">Blocks all outbound calls regardless of service toggles</div>
    </div>
    <label class="toggle">
      <input type="checkbox" id="kill-toggle" onchange="toggleKillAll(this.checked)">
      <span class="slider"></span>
    </label>
  </div>
</div>

<button class="reset-btn" onclick="resetAll()">↺ Re-enable All Services</button>

<script>
async function load() {
  const [stateRes, labelRes] = await Promise.all([
    fetch('/api/state'), fetch('/api/labels')
  ]);
  const state  = await stateRes.json();
  const labels = await labelRes.json();
  renderServices(state, labels);
  document.getElementById('kill-toggle').checked = state.kill_all;
  document.getElementById('kill-card').classList.toggle('active', state.kill_all);
}

function renderServices(state, labels) {
  const container = document.getElementById('services');
  container.innerHTML = '';
  for (const [key, label] of Object.entries(labels)) {
    const enabled = state.services[key] !== false;
    const [name, host] = label.split('  ');
    container.innerHTML += `
      <div class="card" id="card-${key}">
        <div class="card-header">
          <div>
            <div class="service-name">
              <span class="status-dot ${enabled ? 'dot-on' : 'dot-off'}" id="dot-${key}"></span>
              ${name}
            </div>
            <div class="service-host">${host || ''}</div>
          </div>
          <label class="toggle">
            <input type="checkbox" id="toggle-${key}" ${enabled ? 'checked' : ''}
              onchange="toggleService('${key}', this.checked)">
            <span class="slider"></span>
          </label>
        </div>
      </div>`;
  }
}

async function toggleService(key, enabled) {
  await fetch('/api/service/' + key, {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({enabled})
  });
  const dot = document.getElementById('dot-' + key);
  dot.className = 'status-dot ' + (enabled ? 'dot-on' : 'dot-off');
}

async function toggleKillAll(enabled) {
  await fetch('/api/kill_all', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({enabled})
  });
  document.getElementById('kill-card').classList.toggle('active', enabled);
}

async function resetAll() {
  const res = await fetch('/api/state');
  const state = await res.json();
  state.kill_all = false;
  for (const k of Object.keys(state.services)) state.services[k] = true;
  await fetch('/api/state', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(state)
  });
  load();
}

load();
setInterval(load, 4000);
</script>
</body>
