#!/bin/bash
set -euxo pipefail

# =============================================================================
# Spring I/O 2025 — Spring AI + Temporal Workshop
# Track-level VM setup
# Runs once when the track environment is created.
# =============================================================================

# ─── System packages ──────────────────────────────────────────────────────────
# Wait for unattended-upgrades to release the dpkg lock
systemctl disable unattended-upgrades 2>/dev/null || true
systemctl stop unattended-upgrades 2>/dev/null || true
while fuser /var/lib/dpkg/lock-frontend >/dev/null 2>&1; do
    echo "Waiting for dpkg lock..."
    sleep 5
done

apt-get update && apt-get install -y --no-install-recommends \
    wget curl git vim nano unzip ca-certificates bash-completion \
    fontconfig python3 python3-pip python3-venv iptables iproute2 \
    build-essential

# ─── Node.js 18 (required for F1 MCP server) ──────────────────────────────────
curl -fsSL https://deb.nodesource.com/setup_22.x | bash -
apt-get install -y nodejs
node --version
npm --version

# ─── uv (fast Python package installer, used for FastF1 venv) ─────────────────
curl -LsSf https://astral.sh/uv/install.sh | sh
ln -sf /root/.local/bin/uv /usr/local/bin/uv
uv --version

# ─── Java 21 (Eclipse Temurin) ────────────────────────────────────────────────
wget -qO - https://packages.adoptium.net/artifactory/api/gpg/key/public \
    | gpg --dearmor > /etc/apt/trusted.gpg.d/adoptium.gpg
echo "deb https://packages.adoptium.net/artifactory/deb $(awk -F= '/^VERSION_CODENAME/{print $2}' /etc/os-release) main" \
    > /etc/apt/sources.list.d/adoptium.list
apt-get update && apt-get install -y temurin-21-jdk

java -version

# ─── Maven 3.9 ────────────────────────────────────────────────────────────────
MAVEN_VERSION=3.9.9
wget -q "https://archive.apache.org/dist/maven/maven-3/${MAVEN_VERSION}/binaries/apache-maven-${MAVEN_VERSION}-bin.tar.gz" \
    -O /tmp/maven.tar.gz
tar -xzf /tmp/maven.tar.gz -C /opt
ln -s /opt/apache-maven-${MAVEN_VERSION} /opt/maven
ln -s /opt/maven/bin/mvn /usr/local/bin/mvn
rm /tmp/maven.tar.gz

export MAVEN_HOME=/opt/maven
echo "export MAVEN_HOME=/opt/maven" >> /root/.bashrc
echo 'export PATH="${MAVEN_HOME}/bin:${PATH}"' >> /root/.bashrc

mvn -version

# ─── Temporal CLI ─────────────────────────────────────────────────────────────
curl -sSf https://temporal.download/cli.sh | sh
chmod +x /root/.temporalio/bin/temporal
ln -sf /root/.temporalio/bin/temporal /usr/local/bin/temporal

temporal --version

# ─── Temporal dev server (systemd) ────────────────────────────────────────────
mkdir -p /workspace

cat > /etc/systemd/system/temporal-server.service <<'EOF'
[Unit]
Description=Temporal Dev Server
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/temporal server start-dev \
    --ui-port 8080 \
    --ip 0.0.0.0 \
    --db-filename /workspace/temporal.db
Restart=on-failure
RestartSec=5
StandardOutput=append:/workspace/temporal.log
StandardError=append:/workspace/temporal.log

[Install]
WantedBy=multi-user.target
EOF

systemctl enable temporal-server
systemctl start temporal-server

echo "Waiting for Temporal server..."
for i in $(seq 1 30); do
    if temporal operator cluster health --address 127.0.0.1:7233 2>/dev/null | grep -q SERVING; then
        echo "Temporal server healthy."
        break
    fi
    sleep 3
done

# ─── Workshop repo ────────────────────────────────────────────────────────────
git clone https://github.com/temporal-community/springio-agents-springai-temporal.git /workspace/workshop
# NOTE: Update the URL above once the repo is pushed to temporal-community.
# If the repo is still under mmerrell's personal account at track build time,
# use: https://github.com/mmerrell/springio-agents-springai-temporal.git

# Install the pre-built temporal-spring-ai jar into the local Maven repo
cd /workspace/workshop
bash scripts/install-libs.sh

# Pre-warm Maven dependency cache for all four demos
for module in demo1-agentic-loop demo2-springai-temporal-integration demo3-mcp demo4-hitl; do
    echo "Warming Maven cache for $module..."
    mvn -pl "$module" dependency:resolve -q 2>/dev/null || true
done

# Full compile to catch any issues at image build time
mvn -pl demo1-agentic-loop,demo2-springai-temporal-integration,demo3-mcp,demo4-hitl compile -q

# ─── F1 MCP server ────────────────────────────────────────────────────────────
# Pinned to a known-good commit. Update this hash if the upstream repo changes
# in a way that breaks the build.
F1_REPO="https://github.com/rakeshgangwar/f1-mcp-server.git"
F1_COMMIT="73b95ec"
F1_DIR="/workspace/f1-mcp-server"

echo "Cloning F1 MCP server at commit $F1_COMMIT..."
git clone "$F1_REPO" "$F1_DIR"
cd "$F1_DIR"
git checkout "$F1_COMMIT"

# Apply the cache-path patch (already in the workshop repo)
echo "Patching FastF1 cache path..."
sed -i "s|fastf1.Cache.enable_cache.*|import os\n_cache_dir = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), 'cache')\nos.makedirs(_cache_dir, exist_ok=True)\nfastf1.Cache.enable_cache(_cache_dir)|" python/f1_data.py
echo "  Patched."

# Build the Node/TypeScript side
echo "Installing Node dependencies..."
npm install --silent
echo "Building TypeScript..."
npm run build

# Build the Python side with uv
echo "Setting up Python venv for FastF1..."
uv venv -q
source "$F1_DIR/.venv/bin/activate"
uv pip install -q fastf1 pandas numpy
deactivate

# Write mcp-servers.json for demo3 and demo4 with correct VM paths
MCP_JSON=$(cat <<EOF
{
  "mcpServers": {
    "f1-data": {
      "command": "bash",
      "args": ["-c", "source ${F1_DIR}/.venv/bin/activate && node ${F1_DIR}/build/index.js"]
    }
  }
}
EOF
)

for demo in demo3-mcp demo4-hitl; do
    config="/workspace/workshop/${demo}/src/main/resources/mcp-servers.json"
    echo "Writing mcp-servers.json for ${demo}..."
    echo "$MCP_JSON" > "$config"
done

cd /workspace/workshop
echo "F1 MCP server ready at $F1_DIR"

# ─── mitmproxy + network control panel ────────────────────────────────────────

# Install mitmproxy
pip3 install --break-system-packages --ignore-installed mitmproxy

# Install the mitmproxy CA cert into the system and JVM truststores so
# Java code that runs through the proxy doesn't get SSL errors.
# We start mitmproxy briefly to generate the CA cert, then stop it.
mitmdump --listen-port 8889 --set block_global=false &
MITM_PID=$!
sleep 4
kill $MITM_PID 2>/dev/null || true
wait $MITM_PID 2>/dev/null || true

MITM_CERT_DIR="/root/.mitmproxy"
MITM_CA_PEM="$MITM_CERT_DIR/mitmproxy-ca-cert.pem"

# System truststore
cp "$MITM_CA_PEM" /usr/local/share/ca-certificates/mitmproxy-ca.crt
update-ca-certificates

# JVM truststore (Java 21 uses cacerts at $JAVA_HOME/lib/security/cacerts)
JAVA_HOME_PATH=$(dirname $(dirname $(readlink -f $(which java))))
keytool -importcert \
    -trustcacerts \
    -alias mitmproxy \
    -file "$MITM_CA_PEM" \
    -keystore "$JAVA_HOME_PATH/lib/security/cacerts" \
    -storepass changeit \
    -noprompt

# Write the mitmproxy addon script that reads the toggle state
mkdir -p /workspace/proxy

cat > /workspace/proxy/toggle_addon.py <<'PYEOF'
"""
mitmproxy addon: reads /workspace/proxy/state.json and blocks or passes
outbound requests based on which service groups are toggled off.

State file format (written by the control panel UI):
{
  "kill_all": false,
  "services": {
    "openai":      true,
    "weather":     true,
    "geolocation": true,
    "ipinfo":      true,
    "f1":          true
  }
}
A value of `true` means the service is ALLOWED through.
"""
import json
import os
from mitmproxy import http

STATE_FILE = "/workspace/proxy/state.json"

# Maps service keys to the hostname substrings they match
SERVICE_HOSTS = {
    "openai":      ["api.openai.com"],
    "weather":     ["api.open-meteo.com"],
    "geolocation": ["ip-api.com"],
    "ipinfo":      ["icanhazip.com"],
    "f1":          ["ergast.com", "api.openf1.org", "livetiming.formula1.com"],
}

DEFAULT_STATE = {
    "kill_all": False,
    "services": {k: True for k in SERVICE_HOSTS},
}


def _load_state():
    try:
        with open(STATE_FILE) as f:
            return json.load(f)
    except Exception:
        return DEFAULT_STATE


def request(flow: http.HTTPFlow) -> None:
    state = _load_state()
    host = flow.request.pretty_host

    if state.get("kill_all"):
        flow.response = http.Response.make(
            503, b"[Workshop proxy] All external services disabled.", {"Content-Type": "text/plain"}
        )
        return

    services = state.get("services", {})
    for key, hostnames in SERVICE_HOSTS.items():
        if not services.get(key, True):
            if any(h in host for h in hostnames):
                flow.response = http.Response.make(
                    503,
                    f"[Workshop proxy] Service '{key}' is currently disabled.".encode(),
                    {"Content-Type": "text/plain"},
                )
                return
PYEOF

# Write default state file
cat > /workspace/proxy/state.json <<'EOF'
{
  "kill_all": false,
  "services": {
    "openai": true,
    "weather": true,
    "geolocation": true,
    "ipinfo": true,
    "f1": true
  }
}
EOF

# mitmproxy systemd service (transparent proxy on port 8888)
cat > /etc/systemd/system/workshop-proxy.service <<'EOF'
[Unit]
Description=Workshop Network Proxy (mitmproxy)
After=network.target

[Service]
Type=simple
User=root
ExecStart=/usr/local/bin/mitmdump \
    --listen-port 8888 \
    --set block_global=false \
    --set ssl_insecure=false \
    -s /workspace/proxy/toggle_addon.py
Restart=on-failure
RestartSec=3
StandardOutput=append:/workspace/proxy/proxy.log
StandardError=append:/workspace/proxy/proxy.log

[Install]
WantedBy=multi-user.target
EOF

systemctl enable workshop-proxy
systemctl start workshop-proxy

# ─── Control panel UI (Flask) ─────────────────────────────────────────────────
pip3 install --break-system-packages flask

cat > /workspace/proxy/controlpanel.py <<'PYEOF'
"""
Tiny Flask app that serves the network control panel UI.
Reads and writes /workspace/proxy/state.json.
Served on port 5000.
"""
import json, os
from flask import Flask, jsonify, request, send_from_directory

app = Flask(__name__, static_folder="/workspace/proxy/static")
STATE_FILE = "/workspace/proxy/state.json"

DEFAULT_STATE = {
    "kill_all": False,
    "services": {
        "openai": True,
        "weather": True,
        "geolocation": True,
        "ipinfo": True,
    },
}

SERVICE_LABELS = {
    "openai":      "OpenAI  (api.openai.com)",
    "weather":     "Weather  (api.open-meteo.com)",
    "geolocation": "Geolocation  (ip-api.com)",
    "ipinfo":      "IP Info  (icanhazip.com)",
    "f1":          "F1 Data  (ergast.com / api.openf1.org)",
}


def read_state():
    try:
        with open(STATE_FILE) as f:
            return json.load(f)
    except Exception:
        return dict(DEFAULT_STATE)


def write_state(state):
    with open(STATE_FILE, "w") as f:
        json.dump(state, f, indent=2)


@app.route("/")
def index():
    return send_from_directory("/workspace/proxy/static", "index.html")


@app.route("/api/state", methods=["GET"])
def get_state():
    return jsonify(read_state())


@app.route("/api/state", methods=["POST"])
def set_state():
    state = request.get_json(force=True)
    write_state(state)
    return jsonify({"ok": True})


@app.route("/api/service/<key>", methods=["POST"])
def toggle_service(key):
    data = request.get_json(force=True)
    state = read_state()
    state["services"][key] = bool(data.get("enabled", True))
    write_state(state)
    return jsonify({"ok": True, "key": key, "enabled": state["services"][key]})


@app.route("/api/kill_all", methods=["POST"])
def kill_all():
    data = request.get_json(force=True)
    state = read_state()
    state["kill_all"] = bool(data.get("enabled", False))
    write_state(state)
    return jsonify({"ok": True, "kill_all": state["kill_all"]})


@app.route("/api/labels", methods=["GET"])
def labels():
    return jsonify(SERVICE_LABELS)


if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
PYEOF

